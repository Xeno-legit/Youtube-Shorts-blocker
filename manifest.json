{
  "manifest_version": 3,
  "name": "NoShorts: Block YouTube Shorts",
  "version": "1.0",
  "description": "Hides Shorts shelves and redirects Shorts to the normal player.",
  "permissions": ["scripting"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}